# WAH4PC Gateway Configuration
# Required for integration with the Universal Health Care Gateway

# Your Clinic's unique Provider ID (UUID) provided during registration
WAH4PC_PROVIDER_ID=your-provider-uuid-here

# Your API Key for authenticating outgoing requests to the Gateway
WAH4PC_API_KEY=wah_your-api-key-here

# Shared secret key to validate incoming webhooks FROM the Gateway
# Must match the value configured in your Gateway Provider Portal
GATEWAY_AUTH_KEY=your-secret-gateway-auth-key

# Base URL of the Gateway (Production or Staging)
WAH4PC_GATEWAY_URL=https://gateway.wah.ph

# Application URL (for generating return URLs if needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000
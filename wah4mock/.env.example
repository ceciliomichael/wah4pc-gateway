# WAH4PC Gateway Integration Configuration
# ==========================================

# Gateway URL - Change this to the actual gateway address
WAH4PC_GATEWAY_URL=http://host.docker.internal:3040

# Your Provider ID - Obtained after registration with the gateway
WAH4PC_PROVIDER_ID=59cca0b4-0002-4d2b-a284-0db67b5449ee

# Your API Key - Used when sending requests to the gateway
WAH4PC_API_KEY=wah_c45310ac0b59ebcc9d2a479adfc17b5e554f3338d24134fab56eb6a5796dcecd

# Gateway Auth Key - Secret key the gateway uses to authenticate webhook calls to you
# Generate a secure random string and configure it when registering your provider
GATEWAY_AUTH_KEY=tcgtrio123

# This provider's base URL - The URL where the gateway can reach your webhooks
# For local development, you might use ngrok or similar tunneling service
PROVIDER_BASE_URL=http://localhost:3015

# Provider details for registration
PROVIDER_NAME=Clinic ni Pare
PROVIDER_TYPE=clinic

NEXT_PUBLIC_CLINIC_NAME="Clinic ni Pare"
# ===========================================
# Dashboard Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed
# ===========================================

# Backend Service URL (used by Next.js API routes to proxy requests to the Go backend)
BACKEND_URL=http://localhost:8080

# Frontend API Base URL (optional)
# Defaults to /api which routes through Next.js API proxy
# Override this if you want the frontend to call a different API endpoint directly
# NEXT_PUBLIC_API_URL=/api
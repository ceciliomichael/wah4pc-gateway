# ===========================================
# Frontend Docs Environment Configuration
# ===========================================
# Copy this file to .env and update values as needed
# ===========================================

# Gateway URL displayed in documentation examples
# Change this to point to different environments (staging, local, etc.)
NEXT_PUBLIC_GATEWAY_URL=https://gateway.wah4pc.com

# AI Configuration
AI_BASE_URL=http://localhost:1234/v1
AI_API_KEY=localhost
AI_MODEL=qwen/qwen3-vl-4b
AI_TEMPERATURE=0.3
AI_MAX_TOKENS=32000